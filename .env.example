# Bu shablon. Haqiqiy qiymatlar uchun nusxa oling:  cp .env.example .env
# .env fayli .gitignore'da — sirlarni faqat .env'ga yozing, bu faylga emas.

# ===== Telegram =====
# @BotFather'dan olingan bot tokeni
TELEGRAM_BOT_TOKEN=

# Admin Telegram ID'lari (vergul bilan ajratilgan). Masalan: 123456789,987654321
# O'z ID'ingizni bilish uchun botga /start yuboring yoki @userinfobot'dan foydalaning.
ADMIN_IDS=

# ===== Gmail (IMAP) =====
# RingCentral SMS-bildirishnomalari keladigan Gmail manzili
GMAIL_ADDRESS=
# Gmail "App Password" (16 ta belgi). Oddiy parol EMAS!
# 1) Google akkauntda 2-bosqichli tasdiqni yoqing
# 2) https://myaccount.google.com/apppasswords -> yangi app password yarating
GMAIL_APP_PASSWORD=

# RingCentral xatlari keladigan jo'natuvchi manzil (odatda o'zgartirilmaydi)
RINGCENTRAL_SENDER=service@ringcentral.com

# Pochta qutisini necha soniyada bir tekshirish
POLL_INTERVAL=15

# Bu raqamlardan kelgan SMS'lar o'tkazib yuboriladi (vergul bilan ajratilgan)
SKIP_NUMBERS=(833) 963-2500

# IMAP server (Gmail uchun standart)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ===== Ixtiyoriy =====
DATABASE_PATH=bot.db
